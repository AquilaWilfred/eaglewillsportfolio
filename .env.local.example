# ═══════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git
# ═══════════════════════════════════════════════════════

# ── SUPABASE ────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── RESEND ──────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...

# ── CONTACT EMAIL ───────────────────────────────────────
# Where contact form messages should land
CONTACT_EMAIL=wilfredaquila@gmail.com

# ── ADMIN PORTAL ────────────────────────────────────────
# Choose a strong password — this is your admin login
ADMIN_PASSWORD=choose_a_strong_password_here

# A random secret for signing session tokens (generate a random 32-char string)
ADMIN_SECRET=generate_a_random_32_char_string_here
